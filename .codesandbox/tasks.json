{
  "$schema": "https://codesandbox.io/schemas/tasks.json",
  "setupTasks": [
    {
      "name": "Install dependencies",
      "command": "pip install -r requirements.txt"
    }
  ],
  "tasks": {
    "start": {
      "name": "Start server",
      "command": "uvicorn main:app --host 0.0.0.0 --port 8000 --reload",
      "runAtStart": true,
      "preview": {
        "port": 8000
      }
    }
  }
}
